/*
Juego donde debes adivinar el número secreto :b
*/
import java.util.Scanner;
import java.util.Random;
public class NumeroSecreto
{
	public static void main(String[] args) {
	  Random rand = new Random();
	  Scanner sc = new Scanner(System.in);
	  int numeroSecreto = rand.nextInt( 101 );
		System.out.println("Adivina el número secreto del 0 al 100: ");
		int numeroIngre = sc.nextInt();
		while( numeroIngre != numeroSecreto ){
		    System.out.println("Número incorrecto.\nIntenta de nuevo.");
		    
		if ( numeroIngre > numeroSecreto){
		    System.out.println("El número secreto es menor al que ingresaste");
		} else if ( numeroIngre < numeroSecreto){
		    System.out.println("El número secreto es mayor al que ingresaste");
		}
		 numeroIngre = sc.nextInt();   
		} if (numeroIngre == numeroSecreto){
		    System.out.println("¡Lo adivinaste!, el número secreto era "+numeroSecreto);
		}
		
		sc.close();
	}
}
